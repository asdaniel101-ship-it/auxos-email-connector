{
  "version": 2,
  "buildCommand": "cd apps/api && pnpm install && pnpm prisma generate && pnpm build",
  "installCommand": "pnpm install",
  "outputDirectory": "apps/api/dist",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.ts"
    }
  ]
}
