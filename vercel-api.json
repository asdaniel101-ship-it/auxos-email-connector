{
  "version": 2,
  "buildCommand": "npm install && cd apps/api && npm install && npx prisma generate && npm run build",
  "installCommand": "npm install",
  "outputDirectory": "apps/api/dist",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "apps/api/dist/**"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.ts"
    }
  ]
}
