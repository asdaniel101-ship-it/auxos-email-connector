{
  "version": 2,
  "buildCommand": "bash build-api.sh",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "outputDirectory": "apps/api/dist",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "apps/api/dist/**"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.ts"
    }
  ]
}
