{
  "buildCommand": "pnpm install --no-frozen-lockfile && cd apps/api && pnpm prisma generate && cd ../.. && pnpm --filter web run build && pnpm --filter api run build",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "outputDirectory": "apps/web/.next",
  "framework": "nextjs",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api"
    }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "includeFiles": "apps/api/dist/**",
      "nodeVersion": "20.x",
      "memory": 1024
    }
  },
  "crons": []
}
